if(n <= 1) {
    printf("%d is not a prime number\n", n);
} else {
    int a = 0;  // indicator
    for(int i = 2; i <= n/2; i++) {
        if(n % i == 0) {
            a = 1;    // Found a divisor
            break;
        }
    }

    if(a == 0)
        printf("%d is a prime number\n", n);
    else
        printf("%d is not a prime number\n", n);
}
